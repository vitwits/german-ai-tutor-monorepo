# Google Gemini AI Configuration
# Get API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret Key for authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Use at least 32 random characters for security
SECRET_KEY=your_secure_secret_key_here_minimum_32_chars

# Google Cloud Service Account JSON path
# Path inside Docker container (don't change this)
GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/service-account.json

# Azure Speech Services (optional, for TTS)
# Get from: https://portal.azure.com/
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_region_here

# Database Configuration (optional, for PostgreSQL)
# Default is SQLite at backend/data/app.db
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Application Host (optional)
# APP_HOST=0.0.0.0
# APP_PORT=8000